<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:layout_marginTop="4dp"
    android:layout_marginHorizontal="8dp"
    android:background="#FFFFFF"
    android:elevation="4dp"
    android:padding="8dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:padding="12dp">

        <ImageView
            android:id="@+id/imgCategoria"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:scaleType="centerCrop"
            android:clipToOutline="true"
            android:background="@drawable/circle_background"
            android:layout_margin="4dp"/>

        <TextView
            android:id="@+id/txtNomeCategoria"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/imgCategoria"
            android:layout_marginStart="16dp"
            android:layout_centerVertical="true"
            android:text="Nome da Categoria"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"/>

        <ImageView
            android:id="@+id/btnExcluir"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_lixeira"
            android:contentDescription="Excluir"
            android:visibility="gone"/>

        <ImageView
            android:id="@+id/btnEditar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_toStartOf="@id/btnExcluir"
            android:layout_marginEnd="12dp"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_edit"
            android:contentDescription="Editar"
            android:visibility="gone"/>

    </RelativeLayout>
</androidx.cardview.widget.CardView>

