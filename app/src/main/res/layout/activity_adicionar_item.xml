<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:padding="16dp">

        <ImageView
            android:id="@+id/btnVoltar"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_voltar"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:id="@+id/btnSalvar"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_save"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Adicionar Item"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/textos"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/btnVoltar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/imgPrincipal"
            android:layout_width="0dp"
            android:layout_height="350dp"
            android:background="@color/cinza"
            android:scaleType="centerCrop"
            android:contentDescription="Imagem Principal"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnSelecionarImgPrincipal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selecionar imagem principal"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/imgPrincipal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:backgroundTint="@color/azulBotao"
            android:textColor="@color/white"/>

        <EditText
            android:id="@+id/editTextNome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Nome"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/btnSelecionarImgPrincipal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/editTextDescricao"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Descrição"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/editTextNome"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Spinner
            android:id="@+id/spinnerCategoria"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/editTextDescricao"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/imgsSecundariasLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/spinnerCategoria"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/imgSecundaria1"
                android:layout_width="0dp"
                android:layout_height="180dp"
                android:layout_weight="1"
                android:background="@color/cinza"
                android:scaleType="centerCrop"
                android:layout_marginEnd="4dp"
                android:contentDescription="Imagem Secundária 1" />

            <ImageView
                android:id="@+id/imgSecundaria2"
                android:layout_width="0dp"
                android:layout_height="180dp"
                android:layout_weight="1"
                android:background="@color/cinza"
                android:scaleType="centerCrop"
                android:layout_marginStart="4dp"
                android:contentDescription="Imagem Secundária 2" />
        </LinearLayout>

        <Button
            android:id="@+id/btnSelecionarImgSec"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Adicionar imagens secundárias"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/imgsSecundariasLayout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:backgroundTint="@color/azulBotao"
            android:textColor="@color/white"/>


    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>

